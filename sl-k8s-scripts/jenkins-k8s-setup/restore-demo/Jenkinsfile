pipeline {

    // All stages run on the psql-worker. withFileParameter() in the Checkout
    // stage handles copying the uploaded file from the controller to this agent.
    agent { label 'psql-worker' }

    parameters {
        string(
            name: 'TENANT',
            description: 'Target tenant K8s namespace (e.g. abc12345). Must already be provisioned.'
        )
        string(
            name: 'RESTORE_BRANCH',
            defaultValue: 'restore-demo-pipeline',
            description: 'Git branch to check out for SQL scripts. Update to main after this branch is merged.'
        )
        stashedFile(
            name: 'BACKUP_FILE',
            description: 'Upload the production slinkylinky SQL backup file (.sql). ' +
                         'This replaces the tenant\'s entire slinkylinky database with production data.'
        )
    }

    environment {
        MIGRATION_FILE    = "${WORKSPACE}/sl-k8s-scripts/jenkins-k8s-setup/helm/schema-migration.sql"
        GRANTS_FILE       = "${WORKSPACE}/sl-k8s-scripts/jenkins-k8s-setup/restore-demo/post-restore-grants.sql"
        // Use a build-number-scoped path in /tmp so concurrent builds don't clash,
        // and so the file survives the git checkout step that cleans the workspace.
        BACKUP_TEMP_FILE  = "/tmp/production-backup-${BUILD_NUMBER}.sql"
        BACKUP_CLEAN_FILE = "/tmp/production-backup-${BUILD_NUMBER}-clean.sql"
    }

    stages {

        stage('Checkout') {
            steps {
                // withFileParameter copies the uploaded file from the controller workspace
                // to this agent and sets $BACKUP_FILE to its local path. Copy to /tmp
                // BEFORE git checkout, which would clean the workspace and delete it.
                withFileParameter('BACKUP_FILE') {
                    sh 'cp $BACKUP_FILE ${BACKUP_TEMP_FILE}'
                }

                withFolderProperties() {
                    git branch: "${params.RESTORE_BRANCH}",
                        url: "https://${env.GITHUB_PERSONAL_ACCESS_TOKEN}@github.com/rdomloge/slinkylinky.git"
                }
            }
        }

        stage('Scale Down') {
            steps {
                script {
                    withFolderProperties() {
                        withKubeConfig(credentialsId: 'prod-k8s',
                                        serverUrl: "${env.K8S_SERVER_URL}") {
                            sh '''
                            echo "==> Scaling down tenant services: ${TENANT}"
                            kubectl -n ${TENANT} scale --replicas=0 deployment --all
                            kubectl -n ${TENANT} scale --replicas=0 statefulset keycloak rabbit
                            echo "==> Scale down complete."
                            '''
                        }
                    }
                }
            }
        }

        stage('Strip Backup') {
            steps {
                sh '''
                echo "==> Stripping pg18 restrict/unrestrict authentication tokens from backup..."
                # These lines are present in pg_dump output from PostgreSQL 18 and require the
                # original server token to authenticate — they must be removed before loading
                # with psql on a different server.
                grep -vE '^[\\\\](un)?restrict' ${BACKUP_TEMP_FILE} > ${BACKUP_CLEAN_FILE}
                echo "==> Strip complete."
                '''
            }
        }

        stage('Copy Files to Pod') {
            steps {
                script {
                    withFolderProperties() {
                        withKubeConfig(credentialsId: 'prod-k8s',
                                        serverUrl: "${env.K8S_SERVER_URL}") {
                            // Look up the pod name once and store it for subsequent stages.
                            env.POSTGRES_POD = sh(
                                script: "kubectl -n ${params.TENANT} get pod -l app=postgres -o jsonpath='{.items[0].metadata.name}'",
                                returnStdout: true
                            ).trim()
                            sh '''
                            echo "==> Using postgres pod: ${POSTGRES_POD}"
                            # Copy backup and SQL files into the pod as a single bulk transfer —
                            # avoids per-statement network overhead of port-forwarding.
                            kubectl cp ${BACKUP_CLEAN_FILE} ${TENANT}/${POSTGRES_POD}:/tmp/restore.sql
                            kubectl cp ${GRANTS_FILE}       ${TENANT}/${POSTGRES_POD}:/tmp/grants.sql
                            kubectl cp ${MIGRATION_FILE}    ${TENANT}/${POSTGRES_POD}:/tmp/migration.sql
                            echo "==> Copy complete."
                            '''
                        }
                    }
                }
            }
        }

        stage('Restore Database') {
            steps {
                script {
                    withFolderProperties() {
                        withKubeConfig(credentialsId: 'prod-k8s',
                                        serverUrl: "${env.K8S_SERVER_URL}") {
                            sh '''
                            # Ensure the slinkylinky role exists.
                            # Production tables are owned by this role; without it the restore
                            # errors on ALTER TABLE ... OWNER TO slinkylinky statements.
                            echo "==> Ensuring slinkylinky role exists..."
                            kubectl exec -n ${TENANT} ${POSTGRES_POD} -- \
                                sh -c 'PGPASSWORD=CHANGEME psql -U postgres -c "CREATE ROLE slinkylinky;" 2>/dev/null || true'

                            echo "==> Dropping existing schema..."
                            kubectl exec -n ${TENANT} ${POSTGRES_POD} -- \
                                sh -c 'PGPASSWORD=CHANGEME psql -U postgres -d slinkylinky -c "DROP SCHEMA public CASCADE; CREATE SCHEMA public;"'

                            echo "==> Restoring production backup (errors are non-fatal)..."
                            kubectl exec -n ${TENANT} ${POSTGRES_POD} -- \
                                sh -c 'PGPASSWORD=CHANGEME psql -U postgres -d slinkylinky -v ON_ERROR_STOP=0 -f /tmp/restore.sql'

                            echo "==> Restore complete."
                            '''
                        }
                    }
                }
            }
        }

        stage('Post-Restore') {
            steps {
                script {
                    withFolderProperties() {
                        withKubeConfig(credentialsId: 'prod-k8s',
                                        serverUrl: "${env.K8S_SERVER_URL}") {
                            sh '''
                            # Re-apply grants. DROP SCHEMA CASCADE removes all ACLs;
                            # linkservice_user loses access without this.
                            echo "==> Re-applying grants to linkservice_user..."
                            kubectl exec -n ${TENANT} ${POSTGRES_POD} -- \
                                sh -c 'PGPASSWORD=CHANGEME psql -U postgres -d slinkylinky -f /tmp/grants.sql'

                            # Run the idempotent schema migration as postgres superuser.
                            # The migration contains only DDL (ALTER TABLE, DROP/CREATE TRIGGER).
                            # Tables are owned by the slinkylinky role from the production backup,
                            # so linkservice_user cannot alter them — only postgres can.
                            echo "==> Running schema migration..."
                            kubectl exec -n ${TENANT} ${POSTGRES_POD} -- \
                                sh -c 'PGPASSWORD=CHANGEME psql -U postgres -d slinkylinky -f /tmp/migration.sql'

                            # Clean up files from the pod and local temp files.
                            kubectl exec -n ${TENANT} ${POSTGRES_POD} -- \
                                rm -f /tmp/restore.sql /tmp/grants.sql /tmp/migration.sql
                            rm -f ${BACKUP_TEMP_FILE} ${BACKUP_CLEAN_FILE}

                            echo "==> Scaling services back up..."
                            kubectl -n ${TENANT} scale --replicas=1 deployment --all
                            kubectl -n ${TENANT} scale --replicas=1 statefulset --all

                            echo "==> Done. Production data restored into tenant: ${TENANT}"
                            '''
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            // Clean up temp files in case the build failed mid-flight.
            sh 'rm -f ${BACKUP_TEMP_FILE} ${BACKUP_CLEAN_FILE} || true'
        }
        failure {
            script {
                withFolderProperties() {
                    withKubeConfig(credentialsId: 'prod-k8s',
                                    serverUrl: "${env.K8S_SERVER_URL}") {
                        // Always scale back up on failure so the tenant is not left dark.
                        sh '''
                        echo "==> Build failed — scaling services back up..."
                        kubectl -n ${TENANT} scale --replicas=1 deployment --all || true
                        kubectl -n ${TENANT} scale --replicas=1 statefulset --all || true
                        '''
                    }
                }
            }
        }
    }
}
