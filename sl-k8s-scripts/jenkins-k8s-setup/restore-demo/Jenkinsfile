pipeline {

    // All stages run on the psql-worker. withFileParameter() in the Checkout
    // stage handles copying the uploaded file from the controller to this agent.
    agent { label 'psql-worker' }

    parameters {
        string(
            name: 'TENANT',
            description: 'Target tenant K8s namespace (e.g. abc12345). Must already be provisioned.'
        )
        stashedFile(
            name: 'BACKUP_FILE',
            description: 'Upload the production slinkylinky SQL backup file (.sql). ' +
                         'This replaces the tenant\'s entire slinkylinky database with production data.'
        )
    }

    environment {
        MIGRATION_FILE                   = "${WORKSPACE}/sl-k8s-scripts/jenkins-k8s-setup/helm/schema-migration.sql"
        MIGRATION_STATS_FILE             = "${WORKSPACE}/sl-k8s-scripts/jenkins-k8s-setup/helm/schema-migration-stats.sql"
        MIGRATION_AUDIT_FILE             = "${WORKSPACE}/sl-k8s-scripts/jenkins-k8s-setup/helm/schema-migration-audit.sql"
        MIGRATION_SUPPLIERENGAGEMENT_FILE = "${WORKSPACE}/sl-k8s-scripts/jenkins-k8s-setup/helm/schema-migration-supplierengagement.sql"
        GRANTS_FILE           = "${WORKSPACE}/sl-k8s-scripts/jenkins-k8s-setup/restore-demo/post-restore-grants.sql"
        // Use a build-number-scoped path in /tmp so concurrent builds don't clash,
        // and so the file survives the git checkout step that cleans the workspace.
        BACKUP_TEMP_FILE  = "/tmp/production-backup-${BUILD_NUMBER}.sql"
        BACKUP_CLEAN_FILE = "/tmp/production-backup-${BUILD_NUMBER}-clean.sql"
    }

    stages {

        stage('Checkout') {
            steps {
                // withFileParameter copies the uploaded file from the controller workspace
                // to this agent and sets $BACKUP_FILE to its local path. Copy to /tmp
                // BEFORE git checkout, which would clean the workspace and delete it.
                withFileParameter('BACKUP_FILE') {
                    sh 'cp $BACKUP_FILE ${BACKUP_TEMP_FILE}'
                }

                withFolderProperties() {
                    git branch: 'main',
                        url: "https://${env.GITHUB_PERSONAL_ACCESS_TOKEN}@github.com/rdomloge/slinkylinky.git"
                }
            }
        }

        stage('Scale Down') {
            steps {
                script {
                    withFolderProperties() {
                        withKubeConfig(credentialsId: 'prod-k8s',
                                        serverUrl: "${env.K8S_SERVER_URL}") {
                            sh '''
                            echo "==> Scaling down tenant services: ${TENANT}"
                            kubectl -n ${TENANT} scale --replicas=0 deployment --all
                            kubectl -n ${TENANT} scale --replicas=0 statefulset keycloak rabbit
                            echo "==> Scale down complete."
                            '''
                        }
                    }
                }
            }
        }

        stage('Strip Backup') {
            steps {
                sh '''
                echo "==> Stripping pg18 restrict/unrestrict authentication tokens from backup..."
                # These lines are present in pg_dump output from PostgreSQL 18 and require the
                # original server token to authenticate — they must be removed before loading
                # with psql on a different server.
                grep -vE '^[\\\\](un)?restrict' ${BACKUP_TEMP_FILE} > ${BACKUP_CLEAN_FILE}
                echo "==> Strip complete."
                '''
            }
        }

        stage('Copy Files to Pod') {
            steps {
                script {
                    withFolderProperties() {
                        withKubeConfig(credentialsId: 'prod-k8s',
                                        serverUrl: "${env.K8S_SERVER_URL}") {
                            // Look up the pod name once and store it for subsequent stages.
                            env.POSTGRES_POD = sh(
                                script: "kubectl -n ${params.TENANT} get pod -l app=postgres -o jsonpath='{.items[0].metadata.name}'",
                                returnStdout: true
                            ).trim()
                            sh '''
                            echo "==> Using postgres pod: ${POSTGRES_POD}"
                            # Copy backup and SQL files into the pod as a single bulk transfer —
                            # avoids per-statement network overhead of port-forwarding.
                            kubectl cp ${BACKUP_CLEAN_FILE} ${TENANT}/${POSTGRES_POD}:/tmp/restore.sql
                            kubectl cp ${GRANTS_FILE}       ${TENANT}/${POSTGRES_POD}:/tmp/grants.sql
                            kubectl cp ${MIGRATION_FILE}    ${TENANT}/${POSTGRES_POD}:/tmp/migration.sql
                            kubectl cp ${MIGRATION_STATS_FILE} ${TENANT}/${POSTGRES_POD}:/tmp/migration-stats.sql
                            kubectl cp ${MIGRATION_AUDIT_FILE}             ${TENANT}/${POSTGRES_POD}:/tmp/migration-audit.sql
                            kubectl cp ${MIGRATION_SUPPLIERENGAGEMENT_FILE} ${TENANT}/${POSTGRES_POD}:/tmp/migration-supplierengagement.sql
                            echo "==> Copy complete."
                            '''
                        }
                    }
                }
            }
        }

        stage('Restore Database') {
            steps {
                script {
                    withFolderProperties() {
                        withKubeConfig(credentialsId: 'prod-k8s',
                                        serverUrl: "${env.K8S_SERVER_URL}") {
                            sh '''
                            # Ensure the slinkylinky role exists.
                            # Production tables are owned by this role; without it the restore
                            # errors on ALTER TABLE ... OWNER TO slinkylinky statements.
                            echo "==> Ensuring slinkylinky role exists..."
                            kubectl exec -n ${TENANT} ${POSTGRES_POD} -- \
                                sh -c 'PGPASSWORD=CHANGEME psql -U postgres -c "CREATE ROLE slinkylinky;" 2>/dev/null || true'

                            echo "==> Dropping existing schema..."
                            kubectl exec -n ${TENANT} ${POSTGRES_POD} -- \
                                sh -c 'PGPASSWORD=CHANGEME psql -U postgres -d slinkylinky -c "DROP SCHEMA public CASCADE; CREATE SCHEMA public;"'

                            echo "==> Restoring production backup (errors are non-fatal)..."
                            kubectl exec -n ${TENANT} ${POSTGRES_POD} -- \
                                sh -c 'PGPASSWORD=CHANGEME psql -U postgres -d slinkylinky -v ON_ERROR_STOP=0 -f /tmp/restore.sql'

                            echo "==> Restore complete."
                            '''
                        }
                    }
                }
            }
        }

        stage('Post-Restore') {
            steps {
                script {
                    withFolderProperties() {
                        withKubeConfig(credentialsId: 'prod-k8s',
                                        serverUrl: "${env.K8S_SERVER_URL}") {
                            sh '''
                            # Run the idempotent schema migration first so all new tables exist
                            # before grants are applied. GRANT ALL ON ALL TABLES only covers
                            # tables present at grant time — migration must run first.
                            echo "==> Running schema migration..."
                            kubectl exec -n ${TENANT} ${POSTGRES_POD} -- \
                                sh -c 'PGPASSWORD=CHANGEME psql -U postgres -d slinkylinky -f /tmp/migration.sql'

                            # Run stats database migration.
                            echo "==> Running stats schema migration..."
                            kubectl exec -n ${TENANT} ${POSTGRES_POD} -- \
                                sh -c 'PGPASSWORD=CHANGEME psql -U postgres -d stats -f /tmp/migration-stats.sql'

                            # Run audit database migration.
                            echo "==> Running audit schema migration..."
                            kubectl exec -n ${TENANT} ${POSTGRES_POD} -- \
                                sh -c 'PGPASSWORD=CHANGEME psql -U postgres -d audit -f /tmp/migration-audit.sql'

                            # Run supplierengagement database migration.
                            echo "==> Running supplierengagement schema migration..."
                            kubectl exec -n ${TENANT} ${POSTGRES_POD} -- \
                                sh -c 'PGPASSWORD=CHANGEME psql -U postgres -d supplierengagement -f /tmp/migration-supplierengagement.sql'

                            # Re-apply grants. DROP SCHEMA CASCADE removes all ACLs, and
                            # the migration creates new tables that also need grants.
                            echo "==> Re-applying grants..."
                            kubectl exec -n ${TENANT} ${POSTGRES_POD} -- \
                                sh -c 'PGPASSWORD=CHANGEME psql -U postgres -d slinkylinky -f /tmp/grants.sql'

                            # Clean up files from the pod and local temp files.
                            kubectl exec -n ${TENANT} ${POSTGRES_POD} -- \
                                rm -f /tmp/restore.sql /tmp/grants.sql /tmp/migration.sql /tmp/migration-stats.sql /tmp/migration-audit.sql /tmp/migration-supplierengagement.sql
                            rm -f ${BACKUP_TEMP_FILE} ${BACKUP_CLEAN_FILE}

                            echo "==> Scaling services back up..."
                            kubectl -n ${TENANT} scale --replicas=1 deployment --all
                            kubectl -n ${TENANT} scale --replicas=1 statefulset --all

                            echo "==> Done. Production data restored into tenant: ${TENANT}"
                            '''
                        }
                    }
                }
            }
        }

        stage('Configure Keycloak for Demo') {
            steps {
                script {
                    withFolderProperties() {
                        withKubeConfig(credentialsId: 'prod-k8s',
                                        serverUrl: "${env.K8S_SERVER_URL}") {
                            sh '''
                            # After restoring a production DB backup, the slinkylinky database is
                            # backfilled so that all rows belong to the demo org UUID
                            # (00000000-0000-0000-0000-000000000001) by schema-migration.sql.
                            # However, Keycloak is separate from the DB restore — its users retain
                            # whatever org_id attribute they had before (set during provisioning or
                            # a prior restore). The org_id attribute is emitted as a JWT claim by
                            # the Keycloak org_id mapper; if it doesn't match the demo org UUID,
                            # TenantFilter.requireOrgId() returns 403 on every tenant-scoped
                            # endpoint. This stage stamps every user in the realm with the demo
                            # org UUID so tokens align with the restored data.
                            #
                            # Implementation note — why kubectl exec instead of port-forwarding:
                            # The psql-worker Jenkins agent has very few tools available (no jq,
                            # no python3, no ps/pkill). Rather than depend on anything on the
                            # agent, we run all Keycloak Admin API calls inside the Keycloak pod
                            # itself via kubectl exec. curl is always present in the Keycloak
                            # image, and Keycloak listens on localhost:8080 within the pod (8100
                            # is the K8s service port, not the container port). JSON is parsed
                            # with grep + cut — no external tools required on the agent.
                            DEMO_ORG_ID="00000000-0000-0000-0000-000000000001"

                            # Wait for the statefulset rollout before looking up the pod name —
                            # the pod may not be scheduled yet immediately after scale-up.
                            echo "==> Waiting for Keycloak statefulset to roll out..."
                            kubectl -n ${TENANT} rollout status statefulset/keycloak --timeout=180s

                            KEYCLOAK_POD=$(kubectl -n ${TENANT} get pod -l app=keycloak \
                                -o jsonpath='{.items[0].metadata.name}')
                            echo "==> Keycloak pod: ${KEYCLOAK_POD}"

                            echo "==> Obtaining Keycloak admin token..."
                            KC_TOKEN=$(kubectl exec -n ${TENANT} ${KEYCLOAK_POD} -- \
                                curl -sf -X POST \
                                    http://localhost:8080/realms/master/protocol/openid-connect/token \
                                    -d "grant_type=password&client_id=admin-cli&username=admin&password=admin" \
                                | grep -oE '"access_token":"[^"]*"' | cut -d'"' -f4)

                            echo "==> Listing users in realm: ${TENANT}"
                            USER_IDS=$(kubectl exec -n ${TENANT} ${KEYCLOAK_POD} -- \
                                curl -sf \
                                    -H "Authorization: Bearer ${KC_TOKEN}" \
                                    "http://localhost:8080/admin/realms/${TENANT}/users?max=1000" \
                                | grep -oE '"id":"[0-9a-f-]+"' | cut -d'"' -f4)

                            for USER_ID in ${USER_IDS}; do
                                kubectl exec -n ${TENANT} ${KEYCLOAK_POD} -- \
                                    curl -sf -X PUT \
                                        -H "Authorization: Bearer ${KC_TOKEN}" \
                                        -H "Content-Type: application/json" \
                                        -d "{\"attributes\":{\"org_id\":[\"${DEMO_ORG_ID}\"]}}" \
                                        "http://localhost:8080/admin/realms/${TENANT}/users/${USER_ID}"
                                echo "  Updated user ${USER_ID}"
                            done

                            echo "==> Keycloak users configured for demo org."
                            '''
                        }
                    }
                }
            }
        }
    } // end stages

    post {
        always {
            // Clean up local temp files in case the build failed mid-flight.
            sh 'rm -f ${BACKUP_TEMP_FILE} ${BACKUP_CLEAN_FILE} || true'
        }
        failure {
            script {
                withFolderProperties() {
                    withKubeConfig(credentialsId: 'prod-k8s',
                                    serverUrl: "${env.K8S_SERVER_URL}") {
                        // Always scale back up on failure so the tenant is not left dark.
                        sh '''
                        echo "==> Build failed — scaling services back up..."
                        kubectl -n ${TENANT} scale --replicas=1 deployment --all || true
                        kubectl -n ${TENANT} scale --replicas=1 statefulset --all || true
                        '''
                    }
                }
            }
        }
    }
}
