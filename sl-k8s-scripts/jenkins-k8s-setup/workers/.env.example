# External URL of Jenkins on the Pi cluster (LoadBalancer exposes port 8099)
JENKINS_URL=http://10.0.0.X:8099

# Agent secrets for the LOCAL worker nodes (separate Jenkins nodes from the Pi cluster workers).
# For each one: Manage Jenkins -> Nodes -> [node name] -> scroll to "Run from agent command line"
# The secret is the long hex string after "-secret"
#
# IMPORTANT: these are separate nodes from maven-worker, kubectl-worker, etc.
# Give each local node the same LABEL as its Pi counterpart so Jenkins treats them as
# a pool — builds will run on whichever worker is available.
MAVEN_WORKER_LOCAL_SECRET=your_maven_worker_local_secret_here
KUBECTL_WORKER_LOCAL_SECRET=your_kubectl_worker_local_secret_here
HELM_WORKER_LOCAL_SECRET=your_helm_worker_local_secret_here
PSQL_WORKER_LOCAL_SECRET=your_psql_worker_local_secret_here
