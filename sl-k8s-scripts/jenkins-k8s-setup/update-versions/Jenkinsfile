pipeline {
    agent { label 'kubectl-worker' }

    parameters {
        string(
            name: 'IMAGE_VERSION',
            defaultValue: '',
            description: 'Docker image tag to roll out to the tenant workloads'
        )
        string(
            name: 'TENANT',
            defaultValue: '',
            description: 'Tenant namespace to update (for example: abc12345)'
        )
    }

    environment {
        IMAGE_REPOSITORY = 'rdomloge/slinky-linky'
    }

    stages {
        stage('Validate parameters') {
            steps {
                script {
                    if (!params.IMAGE_VERSION?.trim()) {
                        error 'IMAGE_VERSION is required.'
                    }

                    if (!params.TENANT?.trim()) {
                        error 'TENANT is required.'
                    }

                    env.TARGET_IMAGE_VERSION = params.IMAGE_VERSION.trim()
                    env.TARGET_TENANT = params.TENANT.trim()

                    echo "Updating tenant ${env.TARGET_TENANT} to image tag ${env.TARGET_IMAGE_VERSION}"
                }
            }
        }

        stage('Roll deployments') {
            steps {
                script {
                    def workloads = [
                        [displayName: 'audit', deployment: 'audit', container: 'audit', imageSuffix: 'audit'],
                        [displayName: 'frontend', deployment: 'adminwebsite', container: 'adminwebsite', imageSuffix: 'adminwebsite'],
                        [displayName: 'linkservice', deployment: 'linkservice', container: 'linkservice', imageSuffix: 'linkservice'],
                        [displayName: 'stats', deployment: 'stats', container: 'stats', imageSuffix: 'stats'],
                        [displayName: 'supplierengagement', deployment: 'supplierengagement', container: 'supplierengagement', imageSuffix: 'supplierengagement'],
                        [displayName: 'userservice', deployment: 'userservice', container: 'userservice', imageSuffix: 'userservice']
                    ]

                    withFolderProperties() {
                        withKubeConfig(credentialsId: 'prod-k8s', serverUrl: "${env.K8S_SERVER_URL}") {
                            sh "kubectl get namespace ${env.TARGET_TENANT}"

                            def parallelSteps = [:]
                            workloads.each { workload ->
                                def w = workload
                                parallelSteps[w.displayName] = {
                                    def image = "${env.IMAGE_REPOSITORY}-${w.imageSuffix}:${env.TARGET_IMAGE_VERSION}"
                                    echo "Rolling ${w.displayName} using image ${image}"
                                    sh """
                                        kubectl -n ${env.TARGET_TENANT} set image deployment/${w.deployment} ${w.container}=${image}
                                        kubectl -n ${env.TARGET_TENANT} rollout status deployment/${w.deployment} --timeout=5m
                                    """
                                }
                            }
                            parallel parallelSteps
                        }
                    }
                }
            }
        }

        stage('Verify auth security') {
            steps {
                script {
                    withFolderProperties() {
                        sh """
                        BASE_URL="https://${env.TARGET_TENANT}.slinkylinky.uk"
                        FAILURES=0

                        check_protected() {
                            METHOD="\$1"
                            ENDPOINT="\$2"
                            HTTP_CODE=\$(curl -s -o /dev/null -w "%{http_code}" --max-time 10 -X "\$METHOD" "\$BASE_URL\$ENDPOINT")
                            if [ "\$HTTP_CODE" = "401" ]; then
                                echo "  PASS [\$METHOD \$ENDPOINT] -> 401"
                            else
                                echo "  FAIL [\$METHOD \$ENDPOINT] -> \$HTTP_CODE (expected 401)"
                                FAILURES=\$((FAILURES + 1))
                            fi
                        }

                        check_public() {
                            METHOD="\$1"
                            ENDPOINT="\$2"
                            HTTP_CODE=\$(curl -s -o /dev/null -w "%{http_code}" --max-time 10 -X "\$METHOD" "\$BASE_URL\$ENDPOINT")
                            if [ "\$HTTP_CODE" = "401" ]; then
                                echo "  FAIL [\$METHOD \$ENDPOINT] -> 401 (public endpoint should not require auth)"
                                FAILURES=\$((FAILURES + 1))
                            else
                                echo "  PASS [\$METHOD \$ENDPOINT] -> \$HTTP_CODE (not 401)"
                            fi
                        }

                        echo "Waiting for services to be accessible via Cloudflare tunnel..."
                        ATTEMPT=1
                        while [ \$ATTEMPT -le 30 ]; do
                            HTTP_CODE=\$(curl -s -o /dev/null -w "%{http_code}" --max-time 5 "\$BASE_URL/.rest" 2>/dev/null || echo "000")
                            if [ "\$HTTP_CODE" = "401" ] || [ "\$HTTP_CODE" = "200" ]; then
                                echo "Service accessible (HTTP \$HTTP_CODE)"
                                break
                            fi
                            echo "Attempt \$ATTEMPT/30: Got HTTP \$HTTP_CODE — retrying in 10s..."
                            sleep 10
                            ATTEMPT=\$((ATTEMPT + 1))
                        done
                        if [ \$ATTEMPT -gt 30 ]; then
                            echo "ERROR: Services did not become accessible via tunnel within timeout"
                            exit 1
                        fi

                        echo ""
                        echo "=== Auth Security Verification ==="
                        echo ""
                        echo "--- linkservice: Spring Data REST repositories ---"
                        check_protected GET "/.rest/suppliers"
                        check_protected GET "/.rest/demands"
                        check_protected GET "/.rest/demandsites"
                        check_protected GET "/.rest/paidlinks"
                        check_protected GET "/.rest/proposals"
                        check_protected GET "/.rest/categories"
                        echo ""
                        echo "--- linkservice: custom controllers ---"
                        check_protected GET    "/.rest/blackListedSupplierSupport/isBlackListed"
                        check_protected POST   "/.rest/blackListedSupplierSupport/addBlackListed"
                        check_protected POST   "/.rest/aisupport/generate"
                        check_protected DELETE "/.rest/demandsupport/delete"
                        check_protected GET    "/.rest/demandssitesupport/topbydemands"
                        check_protected DELETE "/.rest/demandssitesupport/delete"
                        check_protected GET    "/.rest/paidlinksupport/topbysuppliers"
                        check_protected GET    "/.rest/paidlinksupport/getcountsforsuppliers"
                        check_protected DELETE "/.rest/proposalsupport/abort"
                        check_protected GET    "/.rest/proposalsupport/getProposalsWithOriginalSuppliers"
                        check_protected POST   "/.rest/proposalsupport/createProposal"
                        check_protected PATCH  "/.rest/proposalsupport/addarticle"
                        check_protected POST   "/.rest/proposalsupport/resolveProposal3rdParty"
                        check_protected GET    "/.rest/proposalsupport/responsivenessData"
                        check_protected GET    "/.rest/supplierSupport/list"
                        check_protected PATCH  "/.rest/supplierSupport/updateSupplierDa"
                        check_protected PATCH  "/.rest/supplierSupport/updateSupplierSpam"
                        check_protected GET    "/.rest/supplierSupport/getVersion"
                        check_protected GET    "/.rest/supplierSupport/exists"
                        check_protected POST   "/.rest/supplierSupport/supplierresponse"
                        check_protected GET    "/.rest/supplierHealthSupport/onboarding"
                        check_protected GET    "/.rest/supplierHealthSupport/atrisk"
                        echo ""
                        echo "--- stats ---"
                        check_protected GET "/.rest/stats/fordomain"
                        check_protected GET "/.rest/stats/responsiveness"
                        check_protected GET "/.rest/stats/responsiveness/all"
                        check_protected GET "/.rest/mozsupport/checkdomain"
                        check_protected GET "/.rest/mozsupport/checklink"
                        check_protected GET "/.rest/semrush"
                        echo ""
                        echo "--- audit ---"
                        check_protected GET "/.rest/auditrecords"
                        echo ""
                        echo "--- supplierengagement ---"
                        check_protected GET   "/.rest/engagements"
                        check_protected PATCH "/.rest/leads/0"
                        echo ""
                        echo "--- public endpoints (expect non-401) ---"
                        check_public GET   "/.rest/proposalsupport/getArticleFormatted"
                        check_public PATCH "/.rest/engagements/accept"
                        check_public PATCH "/.rest/engagements/decline"
                        echo ""
                        echo "=== Results: \$FAILURES failure(s) ==="
                        if [ \$FAILURES -ne 0 ]; then
                            echo "SECURITY VERIFICATION FAILED: \$FAILURES endpoint(s) did not respond with the expected auth behaviour"
                            exit 1
                        fi
                        echo "All auth security checks passed."
                        """
                    }
                }
            }
        }
    }
}
