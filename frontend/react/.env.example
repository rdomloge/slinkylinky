# Copy this file to .env and fill in your local values.

# The hostname of the backend API (no trailing slash)
BACKEND_HOST=localhost

# Keycloak connection details
VITE_KEYCLOAK_URL=http://localhost:8100
VITE_KEYCLOAK_REALM=your-realm-name
VITE_KEYCLOAK_CLIENT_ID=your-client-id

# Feature flags
VITE_REGISTRATION_ENABLED=true
VITE_ORDERS_ENABLED=true
